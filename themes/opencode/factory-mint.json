{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg":          "#000000",
    "bg1":         "#0f0e0d",
    "bg2":         "#1a1715",
    "surface":     "#141210",
    "overlay":     "#2a2623",
    "text":        "#f2efec",
    "subtle":      "#b1a8a2",
    "dim":         "#817771",
    "mint":        "#00ffb2",
    "cyan":        "#00e0a0",
    "green":       "#4de8c0",
    "teal":        "#00c490",
    "jade":        "#7adec8",
    "aqua":        "#a8f0de",
    "emerald":     "#00a878",
    "lime":        "#d0f7ec",
    "diffAddBg":   "#001a10",
    "diffRemBg":   "#0a1410"
  },
  "theme": {
    "primary":            { "dark": "mint",    "light": "teal"    },
    "secondary":          { "dark": "cyan",    "light": "cyan"    },
    "accent":             { "dark": "teal",    "light": "teal"    },
    "error":              { "dark": "emerald", "light": "emerald" },
    "warning":            { "dark": "aqua",    "light": "jade"    },
    "success":            { "dark": "green",   "light": "teal"    },
    "info":               { "dark": "jade",    "light": "jade"    },

    "text":               { "dark": "text",    "light": "bg1"     },
    "textMuted":          { "dark": "subtle",  "light": "dim"     },

    "background":         { "dark": "bg",      "light": "text"    },
    "backgroundPanel":    { "dark": "bg1",     "light": "lime"    },
    "backgroundElement":  { "dark": "surface", "light": "aqua"    },

    "border":             { "dark": "bg2",     "light": "jade"    },
    "borderActive":       { "dark": "mint",    "light": "teal"    },
    "borderSubtle":       { "dark": "surface", "light": "aqua"    },

    "diffAdded":          { "dark": "mint",    "light": "teal"    },
    "diffRemoved":        { "dark": "emerald", "light": "emerald" },
    "diffContext":        { "dark": "subtle",  "light": "dim"     },
    "diffHunkHeader":     { "dark": "cyan",    "light": "cyan"    },
    "diffHighlightAdded": { "dark": "mint",    "light": "mint"    },
    "diffHighlightRemoved":{ "dark": "emerald","light": "emerald" },
    "diffAddedBg":        { "dark": "diffAddBg","light": "lime"   },
    "diffRemovedBg":      { "dark": "diffRemBg","light": "aqua"   },
    "diffContextBg":      { "dark": "bg1",     "light": "text"    },
    "diffLineNumber":     { "dark": "dim",     "light": "subtle"  },
    "diffAddedLineNumberBg":  { "dark": "diffAddBg", "light": "lime" },
    "diffRemovedLineNumberBg":{ "dark": "diffRemBg", "light": "aqua" },

    "markdownText":           { "dark": "text",   "light": "bg1"    },
    "markdownHeading":        { "dark": "mint",   "light": "teal"   },
    "markdownLink":           { "dark": "cyan",   "light": "teal"   },
    "markdownLinkText":       { "dark": "jade",   "light": "jade"   },
    "markdownCode":           { "dark": "jade",   "light": "teal"   },
    "markdownBlockQuote":     { "dark": "subtle", "light": "dim"    },
    "markdownEmph":           { "dark": "subtle", "light": "dim"    },
    "markdownStrong":         { "dark": "text",   "light": "bg1"    },
    "markdownHorizontalRule": { "dark": "overlay","light": "jade"   },
    "markdownListItem":       { "dark": "teal",   "light": "teal"   },
    "markdownListEnumeration":{ "dark": "dim",    "light": "dim"    },
    "markdownImage":          { "dark": "cyan",   "light": "cyan"   },
    "markdownImageText":      { "dark": "jade",   "light": "jade"   },
    "markdownCodeBlock":      { "dark": "text",   "light": "bg1"    },

    "syntaxComment":    { "dark": "dim",     "light": "dim"     },
    "syntaxKeyword":    { "dark": "jade",    "light": "teal"    },
    "syntaxFunction":   { "dark": "cyan",    "light": "teal"    },
    "syntaxVariable":   { "dark": "text",    "light": "bg1"     },
    "syntaxString":     { "dark": "lime",    "light": "emerald" },
    "syntaxNumber":     { "dark": "aqua",    "light": "teal"    },
    "syntaxType":       { "dark": "mint",    "light": "teal"    },
    "syntaxOperator":   { "dark": "teal",    "light": "teal"    },
    "syntaxPunctuation":{ "dark": "subtle",  "light": "dim"     }
  }
}
