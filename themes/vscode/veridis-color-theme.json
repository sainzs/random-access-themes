    "sideBarSectionHeader.background":    "#0f0e0d",
    "sideBarSectionHeader.foreground":    "#817771",
    "sideBarSectionHeader.border":        "#1a1715",

    "activityBar.background":             "#0f0e0d",
    "activityBar.foreground":             "#b1a8a2",
    "activityBar.inactiveForeground":     "#817771",
    "activityBar.border":                 "#1a1715",
    "activityBarBadge.background":        "#00ffb2",
    "activityBarBadge.foreground":        "#000000",

    "statusBar.background":               "#000000",
    "statusBar.foreground":               "#817771",
    "statusBar.border":                   "#1a1715",
    "statusBar.noFolderBackground":       "#000000",
    "statusBarItem.hoverBackground":      "#0f0e0d",
    "statusBarItem.activeBackground":     "#141210",

    "titleBar.activeBackground":          "#000000",
    "titleBar.activeForeground":          "#b1a8a2",
    "titleBar.inactiveBackground":        "#000000",
    "titleBar.inactiveForeground":        "#817771",
    "titleBar.border":                    "#1a1715",

    "tab.activeBackground":               "#000000",
    "tab.activeForeground":               "#f2efec",
    "tab.inactiveBackground":             "#0f0e0d",
    "tab.inactiveForeground":             "#817771",
    "tab.border":                         "#1a1715",
    "tab.activeBorder":                   "#00ffb2",
    "tab.unfocusedActiveBorder":          "#00c490",

    "panel.background":                   "#0f0e0d",
    "panel.border":                       "#1a1715",
    "panelTitle.activeForeground":        "#00ffb2",
    "panelTitle.activeBorder":            "#00ffb2",
    "panelTitle.inactiveForeground":      "#817771",

    "terminal.background":                "#000000",
    "terminal.foreground":                "#f2efec",
    "terminal.ansiBlack":                 "#0f0e0d",
    "terminal.ansiRed":                   "#00a878",
    "terminal.ansiGreen":                 "#4de8c0",
    "terminal.ansiYellow":                "#d0f7ec",
    "terminal.ansiBlue":                  "#00e0a0",
    "terminal.ansiMagenta":               "#00c490",
    "terminal.ansiCyan":                  "#7adec8",
    "terminal.ansiWhite":                 "#f2efec",
    "terminal.ansiBrightBlack":           "#817771",
    "terminal.ansiBrightRed":             "#00e0a0",
    "terminal.ansiBrightGreen":           "#4de8c0",
    "terminal.ansiBrightYellow":          "#a8f0de",
    "terminal.ansiBrightBlue":            "#00ffb2",
    "terminal.ansiBrightMagenta":         "#00c490",
    "terminal.ansiBrightCyan":            "#7adec8",
    "terminal.ansiBrightWhite":           "#f2efec",
    "terminalCursor.foreground":          "#00ffb2",

    "input.background":                   "#141210",
    "input.foreground":                   "#f2efec",
    "input.border":                       "#2a2623",
