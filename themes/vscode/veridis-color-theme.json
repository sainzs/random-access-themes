    "list.activeSelectionBackground":     "#141210",
    "list.activeSelectionForeground":     "#00ffb2",
    "list.inactiveSelectionBackground":   "#0f0e0d",
    "list.hoverBackground":               "#141210",
    "list.hoverForeground":               "#f2efec",
    "list.highlightForeground":           "#00ffb2",
    "list.focusHighlightForeground":      "#00ffb2",

    "scrollbar.shadow":                   "#00000000",
    "scrollbarSlider.background":         "#2a262344",
    "scrollbarSlider.hoverBackground":    "#2a2623aa",
    "scrollbarSlider.activeBackground":   "#2a2623cc",

    "widget.shadow":                      "#00000088",
    "focusBorder":                        "#00c490",

    "button.background":                  "#00c490",
    "button.foreground":                  "#000000",
    "button.hoverBackground":             "#00ffb2",

    "badge.background":                   "#00ffb2",
    "badge.foreground":                   "#000000",

    "progressBar.background":             "#00ffb2",

    "gitDecoration.addedResourceForeground":      "#00ffb2",
    "gitDecoration.modifiedResourceForeground":   "#7adec8",
    "gitDecoration.deletedResourceForeground":    "#00a878",
    "gitDecoration.untrackedResourceForeground":  "#4de8c0",
    "gitDecoration.ignoredResourceForeground":    "#817771",
    "gitDecoration.conflictingResourceForeground":"#d0f7ec",

    "diffEditor.insertedTextBackground":  "#00ffb211",
    "diffEditor.removedTextBackground":   "#00a87811"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#817771", "fontStyle": "italic" } },

    { "scope": ["keyword", "keyword.control", "keyword.operator.word", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#7adec8" } },

    { "scope": "keyword.operator",
      "settings": { "foreground": "#00c490" } },

    { "scope": ["entity.name.function", "support.function", "meta.function-call.generic"],
      "settings": { "foreground": "#00e0a0" } },

    { "scope": ["entity.name.type", "entity.name.class", "entity.name.interface", "support.type", "support.class"],
      "settings": { "foreground": "#00ffb2", "fontStyle": "bold" } },

    { "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#a8f0de" } },

    { "scope": "variable.other",
      "settings": { "foreground": "#f2efec" } },

    { "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#d0f7ec" } },

    { "scope": "string.regexp",
      "settings": { "foreground": "#4de8c0" } },

    { "scope": "constant.numeric",
      "settings": { "foreground": "#a8f0de" } },

    { "scope": ["constant.language", "constant.character"],
      "settings": { "foreground": "#7adec8" } },

    { "scope": "punctuation",
      "settings": { "foreground": "#b1a8a2" } },

    { "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#00ffb2" } },

    { "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#7adec8" } },

    { "scope": "support.type.property-name, meta.property-name",
      "settings": { "foreground": "#00e0a0" } },

    { "scope": "invalid",
      "settings": { "foreground": "#f2efec", "background": "#00a878" } },

    // Markdown / notetaking
    { "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#00ffb2", "fontStyle": "bold" } },

    { "scope": "markup.bold",
      "settings": { "foreground": "#f2efec", "fontStyle": "bold" } },

    { "scope": "markup.italic",
      "settings": { "foreground": "#b1a8a2", "fontStyle": "italic" } },

    { "scope": "markup.underline.link",
      "settings": { "foreground": "#00e0a0", "fontStyle": "underline" } },

    { "scope": ["markup.raw.inline", "markup.raw.block"],
      "settings": { "foreground": "#7adec8" } },

    { "scope": "markup.quote",
      "settings": { "foreground": "#b1a8a2", "fontStyle": "italic" } },

    { "scope": "markup.list punctuation.definition",
      "settings": { "foreground": "#00c490" } },

    { "scope": ["markup.inserted", "diff.inserted"],
      "settings": { "foreground": "#00ffb2" } },

    { "scope": ["markup.deleted", "diff.deleted"],
      "settings": { "foreground": "#00a878" } },

    { "scope": ["markup.changed", "diff.changed"],
      "settings": { "foreground": "#7adec8" } }
  ]
}
