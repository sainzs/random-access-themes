    "editor.foreground":                  "#f2efec",
    "editor.lineHighlightBackground":     "#0f0e0d",
    "editor.selectionBackground":         "#2a2623",
    "editor.inactiveSelectionBackground": "#1a1715",
    "editor.findMatchBackground":         "#00c49033",
    "editor.findMatchHighlightBackground":"#00ffb222",
    "editor.wordHighlightBackground":     "#00c49022",
    "editor.wordHighlightStrongBackground":"#00ffb233",
    "editorCursor.foreground":            "#00ffb2",
    "editorLineNumber.foreground":        "#817771",
