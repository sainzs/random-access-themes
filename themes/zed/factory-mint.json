          "preproc":       { "color": "#7adec8" },
          "primary":       { "color": "#f2efec" },
          "property":      { "color": "#00e0a0" },
          "punctuation":   { "color": "#b1a8a2" },
          "punctuation.bracket": { "color": "#b1a8a2" },
