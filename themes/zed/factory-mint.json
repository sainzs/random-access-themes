          "punctuation.special": { "color": "#00c490" },
          "string":        { "color": "#d0f7ec" },
          "string.escape": { "color": "#a8f0de" },
          "string.regex":  { "color": "#4de8c0" },
          "string.special": { "color": "#a8f0de" },
          "string.special.symbol": { "color": "#7adec8" },
          "tag":           { "color": "#00ffb2" },
          "text.literal":  { "color": "#7adec8" },
          "title":         { "color": "#00ffb2", "font_style": "bold" },
          "type":          { "color": "#00ffb2" },
          "variable":      { "color": "#f2efec" },
          "variable.special": { "color": "#a8f0de" },
          "variant":       { "color": "#00ffb2" }
